###############################################################################
# CodeIgniter 4
###############################################################################

# Environment
.env

# Composer dependencies
/vendor/

# Writable folder
/writable/cache/*
/writable/debugbar/*
/writable/logs/*
/writable/session/*
/writable/uploads/*
/writable/database/*

# Keep folder structure
!/writable/cache/index.html
!/writable/debugbar/index.html
!/writable/logs/index.html
!/writable/session/index.html
!/writable/uploads/index.html
!/writable/database/index.html

###############################################################################
# IDE
###############################################################################

.vscode/
.idea/

###############################################################################
# OS Files
###############################################################################

.DS_Store
Thumbs.db
desktop.ini

###############################################################################
# Logs
###############################################################################

*.log

###############################################################################
# Temporary files
###############################################################################

*.tmp
*.temp
*.bak
*.swp

###############################################################################
# Node (kalau nanti pakai Vite/React/Next)
###############################################################################

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

###############################################################################
# Testing
###############################################################################

coverage/

###############################################################################
# Misc
###############################################################################

.env.local
.env.production
.env.development